{
  "name": "playwright-automation",
  "description": "Playwright MCP服务器配置 - 用于浏览器自动化和网页测试",
  "transport": "stdio",
  "command": "playwright-mcp",
  "args": [
    "--browser", "chrome",
    "--headless",
    "--timeout-action", "10000",
    "--timeout-navigation", "30000"
  ],
  "cwd": "C:\\edge_workspace\\cli-server",
  "env": {
    "NODE_ENV": "production"
  },
  "enabled": true,
  "tool_prefix": "playwright",
  "tools": ["*"],
  "configuration_notes": {
    "browser": "使用Chrome浏览器",
    "headless": "无头模式运行，提高性能",
    "timeout_action": "操作超时10秒",
    "timeout_navigation": "导航超时30秒",
    "tool_prefix": "所有工具都以'playwright.'为前缀",
    "tools_available": [
      "browser_close - 关闭浏览器页面",
      "browser_resize - 调整浏览器窗口大小",
      "browser_console_messages - 获取控制台消息",
      "browser_handle_dialog - 处理对话框",
      "browser_evaluate - 执行JavaScript代码",
      "browser_file_upload - 上传文件",
      "browser_fill_form - 填写表单",
      "browser_press_key - 按键操作",
      "browser_type - 输入文本",
      "browser_navigate - 导航到URL",
      "browser_navigate_back - 返回上一页",
      "browser_network_requests - 获取网络请求",
      "browser_run_code - 运行Playwright代码",
      "browser_take_screenshot - 截图",
      "browser_snapshot - 获取页面快照",
      "browser_click - 点击元素",
      "browser_drag - 拖拽操作",
      "browser_hover - 悬停操作",
      "browser_select_option - 选择下拉选项",
      "browser_tabs - 标签页管理",
      "browser_wait_for - 等待条件"
    ]
  },
  "usage_examples": {
    "basic_navigation": {
      "description": "基本网页导航",
      "steps": [
        "playwright.browser_navigate - 打开网页",
        "playwright.browser_snapshot - 获取页面结构",
        "playwright.browser_take_screenshot - 截图"
      ]
    },
    "form_automation": {
      "description": "表单自动化",
      "steps": [
        "playwright.browser_navigate - 打开表单页面",
        "playwright.browser_fill_form - 填写表单字段",
        "playwright.browser_click - 点击提交按钮"
      ]
    },
    "data_extraction": {
      "description": "数据提取",
      "steps": [
        "playwright.browser_navigate - 打开目标页面",
        "playwright.browser_evaluate - 执行数据提取脚本",
        "playwright.browser_network_requests - 分析网络请求"
      ]
    }
  }
}
