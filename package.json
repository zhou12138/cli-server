{
  "name": "cli-server",
  "productName": "CLI Server",
  "version": "0.1.0",
  "description": "Local CLI execution gateway for web-based agents",
  "author": "CLI Server",
  "main": ".vite/build/index.js",
  "scripts": {
    "start": "electron-forge start",
    "start:managed-client": "electron-forge start -- --managed-client-only --enable-managed-client-runtime",
    "start:managed-client-ui": "electron-forge start -- --enable-managed-client-runtime",
    "start:managed-client-mcp-ws": "electron-forge start -- --managed-client-mcp-ws-only --enable-managed-client-mcp-ws",
    "start:managed-client-mcp-ws-ui": "electron-forge start -- --enable-managed-client-mcp-ws --managed-client-mode=managed-client-mcp-ws",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.21.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
