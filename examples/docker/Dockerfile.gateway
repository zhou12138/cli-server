FROM node:22-alpine

# 安装 LandGod Gateway
COPY downloads/landgod-gateway-0.1.0.tgz /tmp/
RUN npm install -g /tmp/landgod-gateway-0.1.0.tgz && rm /tmp/*.tgz

EXPOSE 8080 8081

HEALTHCHECK --interval=30s --timeout=5s \
  CMD wget -qO- http://localhost:8081/health || exit 1

CMD ["landgod-gateway", "start"]
